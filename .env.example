# ---------------------------------------------------------------------------
# Shared secret between the bridge, the MCP server, and the Figma plugin.
# Anyone with this token AND the forwarded bridge URL can join the channel,
# so treat it like a password. Generate one with:  npm run token
# ---------------------------------------------------------------------------
BRIDGE_TOKEN=replace-with-a-long-random-secret

# Port the bridge listens on inside the Codespace. Codespaces forwards this.
BRIDGE_PORT=3055

# How the MCP server reaches the bridge. The MCP server runs in the SAME
# Codespace as the bridge, so this stays on localhost and never leaves the box.
BRIDGE_URL=ws://127.0.0.1:3055

# Logical channel name. Plugin and MCP must use the same value to be paired.
BRIDGE_CHANNEL=default

# Max time (ms) to wait for the plugin to return rendered bytes.
REQUEST_TIMEOUT_MS=30000

# Optional: directory (inside the Codespace) for the saveToFile fallback.
FIGMA_EXPORT_DIR=.figma-exports
