{
  "name": "yasuda-figma-mcp",
  "version": "0.2.0",
  "type": "module",
  "description": "Secure, read-only Figma MCP for GitHub Copilot. Renders locally in the running Figma app (like Copy as PNG) and never uploads to any public S3 URL.",
  "license": "MIT",
  "author": "Rikuto Yasuda",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rikuto-des/yasuda-figma-mcp.git"
  },
  "bin": {
    "yasuda-figma-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "plugin",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "setup": "node scripts/setup.mjs",
    "bridge": "node --env-file-if-exists=.env dist/bridge.js",
    "tunnel": "bash scripts/tunnel.sh",
    "mcp": "node --env-file-if-exists=.env dist/mcp.js",
    "dev:bridge": "tsx watch src/bridge.ts",
    "dev:mcp": "tsx src/mcp.ts",
    "token": "node -e \"import('node:crypto').then(c=>console.log(c.randomBytes(32).toString('hex')))\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
